AI_OFFER_DB_DSN=postgresql://postgres:<password>@localhost:5432/ai_offer_catcher
AI_OFFER_ARTIFACT_ROOT=/path/to/AI_offer_catcher/artifacts
AI_OFFER_MEDIACRAWLER_ROOT=/path/to/AI_offer_catcher/MediaCrawler
AI_OFFER_XHS_INDEX_URL=https://www.xiaohongshu.com
AI_OFFER_ENABLE_CDP=true
AI_OFFER_CDP_HEADLESS=false
AI_OFFER_CDP_CONNECT_EXISTING=true
AI_OFFER_CDP_PORT=9222
AI_OFFER_HEADLESS=false
AI_OFFER_SAVE_LOGIN_STATE=true
AI_OFFER_USER_DATA_DIR=xhs_user_data_dir
AI_OFFER_MAX_CONCURRENCY=1
AI_OFFER_REQUEST_SLEEP_SECONDS=2
AI_OFFER_ENABLE_COMMENTS=false
AI_OFFER_MAX_COMMENTS_PER_POST=20
AI_OFFER_CLASSIFY_MODEL_PATH=/path/to/huggingface_models/Qwen3-VL-4B-Instruct
AI_OFFER_OCR_MODEL_PATH=/path/to/huggingface_models/Qwen3-VL-4B-Instruct
AI_OFFER_EXTRACT_MODEL_PATH=/path/to/huggingface_models/Qwen3-VL-8B-Instruct
AI_OFFER_EMBED_MODEL_PATH=/path/to/huggingface_models/Qwen3-Embedding-4B
AI_OFFER_MODEL_DEVICE=cuda:0
AI_OFFER_SIMILARITY_THRESHOLD=0.86
AI_OFFER_SIMILARITY_REVIEW_THRESHOLD=0.80
AI_OFFER_EMBED_BATCH_SIZE=8
AI_OFFER_PROMPT_DIR=/path/to/AI_offer_catcher/config/prompts
AI_OFFER_KEYWORDS_FILE=/path/to/AI_offer_catcher/config/keywords.txt
